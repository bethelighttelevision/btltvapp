{
  "expo": {
    "owner": "bethelighttelevision",
    "name": "BTL TV",
    "slug": "btl-tv-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "btltv",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#0A0A0F",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.btltv.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.btltv.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "backgroundImage": "./assets/android-icon-background.png",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.btltv.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6dc21843-cb64-4daf-940b-47b041d639d3"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6dc21843-cb64-4daf-940b-47b041d639d3"
    }
  }
}
